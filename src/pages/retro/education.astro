---
// Education — timeline of degrees, newest first.
import PageTransition from '../../components/retro/PageTransition.astro';
import Timeline from '../../components/retro/Timeline.astro';
import type { TimelineItem } from '../../components/retro/Timeline.astro';
import { content } from '../../data/retro-content';

const items: TimelineItem[] = content.education.map((entry) => ({
  heading: entry.title,
  subheading: `${entry.institution} · ${entry.location}`,
  period: entry.period,
  bullets: entry.details,
}));
---

<PageTransition
  title={`Education — ${content.identity.name}`}
  active="education"
  description={`${content.identity.name} — education`}
>
  <section class="px-8 pt-16 pb-6 sm:px-16 lg:pt-20">
    <div class="mx-auto max-w-4xl">
      <p class="page-kicker mb-4 text-xs uppercase">03 — the foundations</p>
      <h2 class="page-title">Education</h2>
    </div>
  </section>

  <section class="px-6 pb-8 sm:px-12">
    <Timeline items={items} />
  </section>
</PageTransition>

<style>
  .page-kicker {
    display: flex;
    align-items: center;
    gap: 0.9rem;
    color: var(--retro-accent);
    letter-spacing: 0.35em;
  }

  .page-kicker::before {
    content: '';
    width: 26px;
    height: 1px;
    background: linear-gradient(90deg, rgba(201, 162, 39, 0.85), var(--retro-accent));
  }

  .page-title {
    font-size: clamp(2.1rem, 5.5vw, 3.6rem);
  }
</style>
