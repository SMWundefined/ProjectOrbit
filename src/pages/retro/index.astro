---
// About — a single viewport, nothing to scroll. A scroll gesture departs
// to Education via the fullpage engine in PageTransition.
import PageTransition from '../../components/retro/PageTransition.astro';
import { content } from '../../data/retro-content';

const { identity, highlights } = content;
---

<PageTransition title={identity.name} active="about" description={`${identity.name} — ${identity.title}`}>
  <section class="relative flex h-dvh flex-col justify-center overflow-hidden px-8 sm:px-16 lg:px-28">
    <div class="max-w-3xl">
      <p class="hero-kicker mb-5 text-xs uppercase">
        {identity.title}
      </p>

      <h1 class="hero-name mb-7 leading-[1.04]">
        {identity.name}
      </h1>

      <div class="max-w-xl space-y-4">
        {
          identity.bio.map((paragraph) => (
            <p class="text-base leading-relaxed sm:text-lg" style="color: var(--retro-text-muted);">
              {paragraph}
            </p>
          ))
        }
      </div>

      <!-- the dial: three measures, no boxes, hairline dividers -->
      <dl class="dial mt-12 flex flex-wrap">
        {
          highlights.map((h) => (
            <div class="dial-item">
              <dt class="dial-label">{h.label}</dt>
              <dd class="dial-value">{h.value}</dd>
            </div>
          ))
        }
      </dl>
    </div>

    <!-- telemetry: a quiet cockpit readout, bottom left -->
    <p class="telemetry absolute bottom-7 left-8 sm:left-16 lg:left-28">
      <span class="telemetry-dot" aria-hidden="true"></span>
      {identity.status}
    </p>

    <!-- continue: scroll, or touch the chevron -->
    <a
      href="/retro/education"
      class="scroll-hint absolute bottom-6 left-1/2 -translate-x-1/2"
      aria-label="Next: Education"
    >
      <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
        <path d="M4 7l6 6 6-6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"></path>
      </svg>
    </a>
  </section>
</PageTransition>

<style>
  .hero-name {
    font-size: clamp(2.6rem, 7.5vw, 5rem);
  }

  /* kicker: a short gold-to-green dash leads the title */
  .hero-kicker {
    display: flex;
    align-items: center;
    gap: 0.9rem;
    color: var(--retro-accent);
    letter-spacing: 0.35em;
  }

  .hero-kicker::before {
    content: '';
    width: 26px;
    height: 1px;
    background: linear-gradient(90deg, rgba(201, 162, 39, 0.85), var(--retro-accent));
  }

  /* ---- the dial: watch-face restraint, no cards ----------------------- */

  .dial {
    margin-left: 0;
  }

  .dial-item {
    padding: 0.2rem 2.2rem 0.2rem 0;
    margin-right: 2.2rem;
    border-right: 1px solid rgba(255, 255, 255, 0.1);
  }

  .dial-item:last-child {
    border-right: none;
    margin-right: 0;
    padding-right: 0;
  }

  .dial-value {
    font-family: var(--retro-font-display);
    font-size: 1.65rem;
    letter-spacing: var(--retro-tracking-wide);
    margin: 0;
  }

  .dial-label {
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.22em;
    color: var(--retro-gray);
    margin-bottom: 0.45rem;
    transition: color var(--retro-dur-fast) ease;
  }

  .dial-item:hover .dial-label {
    color: #c9a227;
  }

  /* ---- telemetry -------------------------------------------------------- */

  .telemetry {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-family: ui-monospace, 'Cascadia Code', Consolas, monospace;
    font-size: 0.66rem;
    letter-spacing: 0.18em;
    color: var(--retro-gray);
  }

  .telemetry-dot {
    width: 5px;
    height: 5px;
    border-radius: 9999px;
    background: #c9a227;
    box-shadow: 0 0 8px rgba(201, 162, 39, 0.7);
    animation: retro-pulse 2.6s ease-in-out infinite;
  }

  .scroll-hint {
    color: var(--retro-gray);
    animation: retro-drift-down 2.4s var(--retro-ease) infinite;
    transition: color var(--retro-dur-fast) ease;
  }

  .scroll-hint:hover {
    color: #c9a227;
  }

  @media (max-width: 640px) {
    .dial-item {
      padding-right: 1.4rem;
      margin-right: 1.4rem;
      margin-bottom: 0.8rem;
    }
    .telemetry {
      display: none; /* the hero breathes on small screens */
    }
  }
</style>
