---
// Identity comes from .env (PUBLIC_*) so no personal detail lives in source.
const user = import.meta.env.PUBLIC_TERMINAL_USER ?? 'guest';
const host = import.meta.env.PUBLIC_TERMINAL_HOST ?? 'orbit';
const title = import.meta.env.PUBLIC_SITE_TITLE ?? `${user}@${host}: ~`;
const prompt = `${user}@${host}:~$`;

const contact = {
  github: import.meta.env.PUBLIC_GITHUB_URL ?? '',
  linkedin: import.meta.env.PUBLIC_LINKEDIN_URL ?? '',
  email: import.meta.env.PUBLIC_CONTACT_EMAIL ?? '',
  website: import.meta.env.PUBLIC_WEBSITE_URL ?? '',
};

const lastLogin = new Date().toLocaleString('en-US', {
  weekday: 'short',
  month: 'short',
  day: 'numeric',
  hour: '2-digit',
  minute: '2-digit',
});
---

<div class="relative flex min-h-screen items-center justify-center overflow-hidden bg-page p-0 font-mono sm:p-6">
  <!-- Ambient backdrop: racing green + gold glows, pointer parallax -->
  <div id="backdrop" aria-hidden="true" class="pointer-events-none absolute inset-0 will-change-transform">
    <div class="animate-glow-drift absolute -top-1/3 -left-1/4 h-[70vmax] w-[70vmax] rounded-full bg-accent-green/30 blur-[120px]"></div>
    <div
      class="animate-glow-drift absolute -right-1/4 -bottom-1/3 h-[50vmax] w-[50vmax] rounded-full bg-accent-gold/10 blur-[140px]"
      style="animation-delay: -15s; animation-direction: alternate-reverse;"
    >
    </div>
    <div id="streak"></div>
  </div>

  <div
    id="terminal-window"
    class="animate-fade-in relative flex h-dvh w-full max-w-4xl flex-col overflow-hidden bg-term-bg shadow-2xl sm:h-[85vh] sm:rounded-xl sm:border sm:border-term-border"
  >
    <!-- Title bar -->
    <div class="flex items-center justify-between border-b border-term-border bg-term-chrome px-4 py-2.5">
      <span class="text-xs text-term-muted select-none">{title}</span>
      <div class="flex items-center gap-4 text-term-muted select-none" aria-hidden="true">
        <span class="text-xs leading-none">&#x2500;</span>
        <span class="text-xs leading-none">&#x25A1;</span>
        <span class="text-xs leading-none">&#x2715;</span>
      </div>
    </div>

    <!-- Terminal canvas -->
    <div
      id="terminal-content"
      data-prompt={prompt}
      data-github={contact.github}
      data-linkedin={contact.linkedin}
      data-email={contact.email}
      data-website={contact.website}
      class="min-h-0 flex-1 cursor-text overflow-y-auto overscroll-contain p-4 text-sm leading-relaxed text-term-green sm:p-6"
    >
      <div class="mb-4">
        <p class="text-term-muted">Last login: {lastLogin}</p>
        <p class="mt-2">Welcome to {host}.</p>
        <p>Type <span class="text-term-blue">help</span> to get started.</p>
      </div>

      <div id="command-history"></div>

      <div class="relative flex" id="current-prompt">
        <span class="shrink-0 text-term-blue">{prompt}&nbsp;</span>
        <span id="typed-text" class="break-all whitespace-pre-wrap"></span>
        <span id="cursor" class="animate-blink select-none" aria-hidden="true">&#x258B;</span>
        <label for="command-input" class="sr-only">Terminal command input</label>
        <input
          type="text"
          id="command-input"
          class="absolute h-px w-px opacity-0"
          autocomplete="off"
          autocapitalize="off"
          autocorrect="off"
          spellcheck="false"
        />
      </div>
    </div>
  </div>
</div>

<script>
  // Pointer parallax on the backdrop — desktop only, skipped for reduced motion.
  const backdrop = document.getElementById('backdrop');
  const finePointer = matchMedia('(pointer: fine)').matches;
  const reducedMotion = matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (backdrop && finePointer && !reducedMotion) {
    let targetX = 0,
      targetY = 0,
      currentX = 0,
      currentY = 0,
      raf = 0;

    const render = () => {
      currentX += (targetX - currentX) * 0.06;
      currentY += (targetY - currentY) * 0.06;
      backdrop.style.transform = `translate3d(${currentX}px, ${currentY}px, 0)`;
      if (Math.abs(targetX - currentX) + Math.abs(targetY - currentY) > 0.1) {
        raf = requestAnimationFrame(render);
      } else {
        raf = 0;
      }
    };

    addEventListener(
      'pointermove',
      (e) => {
        targetX = (e.clientX / innerWidth - 0.5) * 24;
        targetY = (e.clientY / innerHeight - 0.5) * 16;
        if (!raf) raf = requestAnimationFrame(render);
      },
      { passive: true }
    );
  }

  // Occasional light streak across the backdrop — once every 15–30s,
  // random position and angle, mostly gold with the odd green pass.
  const streak = document.getElementById('streak');

  if (streak && !reducedMotion) {
    const shoot = () => {
      const startX = Math.random() * innerWidth * 0.6;
      const startY = Math.random() * innerHeight * 0.4;
      const angle = 18 + Math.random() * 24;
      const distance = 420 + Math.random() * 380;
      const rad = (angle * Math.PI) / 180;
      const dx = Math.cos(rad) * distance;
      const dy = Math.sin(rad) * distance;
      const gold = Math.random() < 0.7;

      streak.style.setProperty(
        '--streak-color',
        gold ? 'var(--color-accent-gold)' : 'var(--color-term-green)'
      );

      streak.animate(
        [
          {
            transform: `translate(${startX}px, ${startY}px) rotate(${angle}deg)`,
            opacity: 0,
          },
          { opacity: 0.55, offset: 0.25 },
          {
            transform: `translate(${startX + dx}px, ${startY + dy}px) rotate(${angle}deg)`,
            opacity: 0,
          },
        ],
        { duration: 1100 + Math.random() * 500, easing: 'cubic-bezier(0.2, 0.6, 0.4, 1)' }
      );

      setTimeout(shoot, 5000 + Math.random() * 5000);
    };

    setTimeout(shoot, 3000 + Math.random() * 3000);
  }
</script>

<script type="module" src="/scripts/terminal.js"></script>
