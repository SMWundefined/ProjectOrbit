---
// Navigation as a black hole. Closed: a thin event-horizon ring with a
// gold particle in orbit. Open: the ring collapses to a singularity, the
// particle falls in, and two bent light rays form the ✕. The overlay is a
// translucent veil — the neural field stays alive behind it — and choosing
// a destination warps you there: the menu stretches past the viewer like
// crossing a wormhole, then the page changes.
interface Props {
  /** key of the current page so the menu can mark it */
  active?: 'about' | 'education' | 'experience' | 'projects' | 'skills' | 'contact';
}
const { active } = Astro.props;

const links = [
  { label: 'About', href: '/retro', key: 'about' },
  { label: 'Experience', href: '/retro/experience', key: 'experience' },
  { label: 'Education', href: '/retro/education', key: 'education' },
  { label: 'Projects', href: '/retro/projects', key: 'projects' },
  { label: 'Skills & Certs', href: '/retro/skills', key: 'skills' },
  { label: 'Contact', href: '/retro/contact', key: 'contact' },
] as const;
---

<button
  id="nav-burger"
  type="button"
  aria-label="Open menu"
  aria-expanded="false"
  aria-controls="nav-overlay"
  title="cross the event horizon"
>
  <span class="disk"></span>
  <span class="horizon"></span>
  <span class="particle"></span>
  <span class="ray ray-1"></span>
  <span class="ray ray-2"></span>
</button>

<nav id="nav-overlay" aria-hidden="true">
  <ul>
    {
      links.map((link, i) => (
        <li class="menu-item" style={`--i: ${i}`}>
          <a href={link.href} aria-current={active === link.key ? 'page' : undefined}>
            <span class="index">0{i + 1}</span>
            <span class="label">{link.label}</span>
          </a>
        </li>
      ))
    }
  </ul>
</nav>

<style>
  /* ---- the black hole ------------------------------------------------ */
  #nav-burger {
    position: fixed;
    top: 50%;
    right: 1rem;
    transform: translateY(-50%);
    z-index: 50;
    width: 64px;
    height: 64px;
    border: none;
    border-radius: 9999px;
    cursor: pointer;
    /* no chrome — the hole carries its own darkness: a true-black core
       deepening out of the page, a whisper of bent light at the rim,
       then nothing. The aura, not a button. */
    background: radial-gradient(
      circle,
      #000 0%,
      #000 26%,
      rgba(0, 0, 0, 0.72) 42%,
      rgba(255, 255, 255, 0.035) 58%,
      transparent 72%
    );
    /* faint lensing of the field behind it */
    backdrop-filter: blur(2.5px);
  }

  #nav-burger:focus-visible {
    outline: 1px solid rgba(3, 122, 104, 0.6);
    outline-offset: 4px;
  }

  /* event horizon: a black disc rimmed by a thin photon ring —
     darker than everything around it, the way a hole should be */
  .horizon {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 18px;
    height: 18px;
    margin: -9px 0 0 -9px;
    background: #000;
    border: 1px solid rgba(255, 255, 255, 0.75);
    border-radius: 9999px;
    transition:
      transform var(--retro-dur) var(--retro-ease),
      background var(--retro-dur) var(--retro-ease),
      border-color var(--retro-dur) ease,
      box-shadow var(--retro-dur) ease;
  }

  /* the orbiting particle — accretion in miniature */
  .particle {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 3.5px;
    height: 3.5px;
    margin: -1.75px;
    border-radius: 9999px;
    background: #c9a227;
    animation: orbit 3.2s linear infinite;
    transition: opacity var(--retro-dur-fast) ease;
  }

  @keyframes orbit {
    from {
      transform: rotate(0deg) translateX(13px);
    }
    to {
      transform: rotate(360deg) translateX(13px);
    }
  }

  /* the edge-on accretion disk — Gargantua's horizontal blade of light */
  .disk {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 30px;
    height: 1px;
    margin: -0.5px 0 0 -15px;
    border-radius: 9999px;
    background: linear-gradient(
      90deg,
      transparent,
      rgba(201, 162, 39, 0.9) 30%,
      #fff8e1 50%,
      rgba(201, 162, 39, 0.9) 70%,
      transparent
    );
    transform: scaleX(0);
    transition: transform 500ms var(--retro-ease);
  }

  /* hover: it becomes Gargantua — horizon ignites gold with a photon
     halo, the disk blazes through, the orbit accelerates */
  #nav-burger:hover:not(.open) .horizon {
    border-color: #c9a227;
    box-shadow:
      0 0 8px rgba(201, 162, 39, 0.9),
      0 0 22px rgba(201, 162, 39, 0.45),
      inset 0 0 6px rgba(201, 162, 39, 0.35);
  }
  #nav-burger:hover:not(.open) .disk {
    transform: scaleX(1);
  }
  #nav-burger:hover:not(.open) .particle {
    animation-duration: 1.1s;
    box-shadow: 0 0 6px rgba(201, 162, 39, 0.9);
  }

  /* bent light rays — hidden until they form the ✕ */
  .ray {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 20px;
    height: 1.5px;
    margin: -0.75px 0 0 -10px;
    border-radius: 9999px;
    background: var(--retro-accent);
    transform: scaleX(0);
    transition: transform var(--retro-dur) var(--retro-ease);
  }

  /* open: collapse, swallow, lens */
  #nav-burger.open .horizon {
    transform: scale(0.4);
    background: var(--retro-text);
    border-color: var(--retro-text);
  }
  #nav-burger.open .particle {
    opacity: 0; /* past the event horizon */
  }
  #nav-burger.open .ray-1 {
    transform: rotate(45deg) scaleX(1);
  }
  #nav-burger.open .ray-2 {
    transform: rotate(-45deg) scaleX(1);
  }

  /* ---- overlay: a veil, not a wall ----------------------------------- */
  #nav-overlay {
    position: fixed;
    inset: 0;
    z-index: 40;
    display: grid;
    place-items: center;
    background: rgba(0, 0, 0, 0.42);
    backdrop-filter: blur(5px) saturate(1.1);
    clip-path: circle(0px at calc(100% - 3rem) 50%);
    visibility: hidden;
    transition:
      clip-path 600ms var(--retro-ease),
      visibility 0s linear 600ms;
  }

  #nav-overlay.open {
    clip-path: circle(150% at calc(100% - 3rem) 50%);
    visibility: visible;
    transition:
      clip-path 700ms var(--retro-ease),
      visibility 0s;
  }

  #nav-overlay ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: clamp(0.6rem, 2.5vh, 1.4rem);
    /* the singularity sits up and to the right — everything falls there */
    transform-origin: 115% -15%;
  }

  /* the warp: a slow gravitational grab — a moment of resistance, a tilt
     as spacetime shears, then the plunge into the singularity */
  @keyframes warp-fall {
    0% {
      transform: scale(1) rotate(0deg);
      filter: blur(0);
      opacity: 1;
    }
    30% {
      transform: scale(1.05) rotate(-1deg);
      filter: blur(0.5px);
      opacity: 1;
    }
    100% {
      transform: scale(0.03) rotate(14deg);
      filter: blur(16px);
      opacity: 0;
    }
  }

  #nav-overlay.warping ul {
    animation: warp-fall 1000ms cubic-bezier(0.7, 0, 0.95, 0.4) forwards;
  }

  /* the well deepens as you fall */
  #nav-overlay.warping {
    background: rgba(0, 0, 0, 0.78);
    transition: background 900ms ease-in;
  }

  .menu-item {
    opacity: 0;
    transform: translateY(16px);
    transition:
      opacity var(--retro-dur) var(--retro-ease),
      transform var(--retro-dur) var(--retro-ease);
  }

  #nav-overlay.open .menu-item {
    opacity: 1;
    transform: none;
    transition-delay: calc(180ms + var(--i) * 70ms);
  }

  .menu-item a {
    display: flex;
    align-items: baseline;
    gap: 1.25rem;
    text-decoration: none;
    color: var(--retro-text);
    font-family: var(--retro-font-display);
    font-size: clamp(1.7rem, 5.5vw, 3rem);
    letter-spacing: var(--retro-tracking-wide);
    font-weight: 500;
    padding: 0.1em 0;
  }

  .index {
    font-family: var(--retro-font-body);
    font-size: 0.85rem;
    color: var(--retro-gray);
    letter-spacing: 0.2em;
    transition: color var(--retro-dur-fast) ease;
  }

  /* hover: space itself stretches — tracking expands, a pathway draws */
  .label {
    position: relative;
    transition:
      letter-spacing 450ms var(--retro-ease),
      text-shadow 450ms ease;
  }

  .label::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: -4px;
    height: 1px;
    width: 100%;
    background: linear-gradient(90deg, var(--retro-accent), rgba(201, 162, 39, 0.6), transparent);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 450ms var(--retro-ease);
  }

  .menu-item a:hover .label {
    letter-spacing: 0.22em;
    text-shadow: 0 0 18px rgba(3, 122, 104, 0.5);
  }
  .menu-item a:hover .label::after {
    transform: scaleX(1);
  }
  .menu-item a:hover .index {
    color: var(--retro-accent);
  }

  .menu-item a[aria-current='page'] .label {
    color: var(--retro-accent);
  }
  .menu-item a[aria-current='page'] .label::after {
    transform: scaleX(1);
    opacity: 0.5;
  }

  @media (max-width: 640px) {
    #nav-burger {
      top: 0.6rem;
      right: 0.6rem;
      transform: none;
    }
    #nav-overlay {
      clip-path: circle(0px at calc(100% - 2.6rem) 2.6rem);
    }
    #nav-overlay.open {
      clip-path: circle(150% at calc(100% - 2.6rem) 2.6rem);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    #nav-overlay,
    #nav-overlay.open,
    #nav-overlay ul,
    .menu-item,
    .horizon,
    .ray,
    .label {
      transition-duration: 0.01ms !important;
    }
    .particle {
      animation: none;
    }
  }
</style>

<script>
  const burger = document.getElementById('nav-burger');
  const overlay = document.getElementById('nav-overlay');
  const reducedMotion = matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (burger && overlay) {
    const setOpen = (open: boolean): void => {
      burger.classList.toggle('open', open);
      overlay.classList.toggle('open', open);
      burger.setAttribute('aria-expanded', String(open));
      burger.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
      overlay.setAttribute('aria-hidden', String(!open));
      document.body.style.overflow = open ? 'hidden' : '';
    };

    burger.addEventListener('click', () => setOpen(!burger.classList.contains('open')));

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && burger.classList.contains('open')) setOpen(false);
    });

    // warp jump: stretch the menu past the viewer, then navigate
    overlay.querySelectorAll('a').forEach((a) => {
      a.addEventListener('click', (e) => {
        const href = a.getAttribute('href');
        if (!href) return;
        e.preventDefault();
        if (a.getAttribute('aria-current') === 'page') {
          setOpen(false);
          return;
        }
        if (reducedMotion) {
          location.assign(href);
          return;
        }
        overlay.classList.add('warping');
        window.setTimeout(() => location.assign(href), 1000);
      });
    });

    // broadcast gravity to the neural field while the black hole is hovered
    burger.addEventListener('pointerenter', () => {
      const rect = burger.getBoundingClientRect();
      window.dispatchEvent(
        new CustomEvent('orbit:gravity-on', {
          detail: { x: rect.left + rect.width / 2, y: rect.top + rect.height / 2 },
        })
      );
    });
    burger.addEventListener('pointerleave', () => {
      window.dispatchEvent(new CustomEvent('orbit:gravity-off'));
    });
  }
</script>
