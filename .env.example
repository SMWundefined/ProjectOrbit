# ProjectOrbit environment configuration
# Copy this file to .env and fill in your values. Never commit .env.

# --- RAG ingestion (scripts/ingest.py) ---

# Directory where ChromaDB persists the vector store (gitignored)
CHROMA_PATH=./chroma_db

# Directory containing your personal markdown data files
DATA_DIR=./src/data

# Embedding model — must be the same at ingestion time and query time
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# --- AI chat endpoint (src/pages/api/chat.ts) ---

# Base URL of your local Ollama server
OLLAMA_HOST=http://localhost:11434

# Ollama model used to generate answers (pull it first: ollama pull <model>)
OLLAMA_MODEL=

# --- Public fallback links (returned when the AI has no good answer) ---
# Kept in env so no personal URL is hardcoded in source code

PUBLIC_GITHUB_URL=
PUBLIC_LINKEDIN_URL=

# --- AWS (later phase — leave empty for now) ---
# AWS_REGION=
# S3_BUCKET_NAME=
