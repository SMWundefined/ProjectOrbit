# ProjectOrbit environment configuration
# Copy this file to .env and fill in your values. Never commit .env.

# --- RAG ingestion (scripts/ingest.py) ---

# Directory where ChromaDB persists the vector store (gitignored)
CHROMA_PATH=./chroma_db

# Directory containing your personal markdown data files
DATA_DIR=./src/data

# Embedding model — must be the same at ingestion time and query time
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# --- AI chat endpoint (src/pages/api/chat.ts) ---

# Groq API key — create one free at https://console.groq.com (API Keys).
# When set, answers are generated by Groq; when empty, the endpoint falls
# back to local Ollama so dev works without a key.
GROQ_API_KEY=

# Groq model (free tier; same llama 3.1 family as the local fallback)
GROQ_MODEL=llama-3.1-8b-instant

# Base URL of your local Ollama server (fallback / local dev)
OLLAMA_HOST=http://localhost:11434

# Ollama model used to generate answers (pull it first: ollama pull <model>)
OLLAMA_MODEL=llama3.1:latest

# Retrieval sidecar (python scripts/rag_server.py)
RAG_SERVER_URL=http://127.0.0.1:8001
RAG_SERVER_PORT=8001

# Bind address — leave localhost-only; Docker compose overrides to 0.0.0.0
RAG_SERVER_HOST=127.0.0.1

# Below this cosine similarity the endpoint answers with fallback links
# instead of asking the LLM (range 0-1; raise it to be stricter)
RAG_MIN_SIMILARITY=0.32

# --- Site identity (rendered in the terminal UI at build time) ---
# Kept in env so no name, email, or URL is hardcoded in source code

# Terminal window title bar text (e.g. "Jane Subsystem for Linux")
PUBLIC_SITE_TITLE=

# Browser tab title for the terminal site (falls back to PUBLIC_SITE_TITLE)
PUBLIC_TAB_TITLE=

# Terminal prompt renders as <user>@<host>:~$
PUBLIC_TERMINAL_USER=
PUBLIC_TERMINAL_HOST=

# --- Contact links (shown by the `contact` command and AI fallbacks) ---

PUBLIC_GITHUB_URL=
PUBLIC_LINKEDIN_URL=
PUBLIC_CONTACT_EMAIL=
PUBLIC_WEBSITE_URL=

# --- AWS (later phase — leave empty for now) ---
# AWS_REGION=
# S3_BUCKET_NAME=
